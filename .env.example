# Default offline provider. No network or API key is required.
BUBBLE_AGENT_DEFAULT_PROVIDER=demo
BUBBLE_AGENT_DEFAULT_MODEL=bubble-demo-v1

# To use an OpenAI-compatible provider, replace the values below and keep the real
# secret only in your local .env or process environment. Never commit the real key.
# BUBBLE_AGENT_DEFAULT_PROVIDER=openai-compatible
# BUBBLE_AGENT_DEFAULT_MODEL=your-model
# BUBBLE_AGENT_MODEL_BASE_URL=https://example.com/v1
# BUBBLE_AGENT_MODEL_API_KEY=replace-locally

BUBBLE_AGENT_HOST=127.0.0.1
BUBBLE_AGENT_PORT=8765
BUBBLE_AGENT_DATA_DIR=./data
